# ═══════════════════════════════════════════════════════════
# Voice & Video Cloner — Environment Variables
# Copy this as .env in the project root and edit values.
# ═══════════════════════════════════════════════════════════

# Flask
FLASK_ENV=production
FLASK_DEBUG=0

# Secret key (generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_STRING

# Upload limit (200 MB default)
MAX_CONTENT_LENGTH=209715200

# Gunicorn
WORKERS=2
BIND=127.0.0.1:5000
